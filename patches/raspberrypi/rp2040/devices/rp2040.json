      "kind": "xip-flash",
      "base_address": 268435456,
      "size_bytes": 16777216,
      "access": "rx"
    }
  ],
  "dma_request_refs": [
    "dma-uart0-rx", "dma-uart0-tx",
    "dma-uart1-rx", "dma-uart1-tx",
    "dma-spi0-rx",  "dma-spi0-tx",
    "dma-spi1-rx",  "dma-spi1-tx",
    "dma-adc"

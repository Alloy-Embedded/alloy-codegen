      "pclk_hz": 6000000,
      "source_hz": 6000000
    },
    {
      "profile_id": "default-pll-125mhz",
      "kind": "default",
      "source_kind": "pll-external",
      "sysclk_hz": 125000000,
      "hclk_hz": 125000000,
      "pclk_hz": 125000000,
      "source_hz": 12000000,
      "pll_n": 125,
      "pll_p": 6,
      "pll_q": 2
    }
  ]

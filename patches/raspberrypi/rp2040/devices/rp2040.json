{
  "patch_id": "raspberrypi-rp2040-bootstrap",
  "device": "rp2040",
  "svd_file": "rp2040.svd",
  "package": "qfn56",
  "core": "cortex-m0plus-dual",
  "summary": "Raspberry Pi RP2040 dual-core Cortex-M0+ SoC (single-core-perspective, core 0).",
  "memories": [

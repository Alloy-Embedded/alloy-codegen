<?xml version="1.0" encoding="utf-8"?>
<device>
  <name>STM32G0B1</name>
  <version>2.1</version>
  <description>STM32G0B1 bootstrap fixture</description>
  <peripherals>
    <peripheral>
      <name>GPIOA</name>
      <baseAddress>0x50000000</baseAddress>
    </peripheral>
    <peripheral>
      <name>GPIOB</name>
      <baseAddress>0x50000400</baseAddress>
    </peripheral>
    <peripheral>
      <name>RCC</name>
      <baseAddress>0x40021000</baseAddress>
      <interrupt>
        <name>RCC_CRS</name>
        <value>4</value>
      </interrupt>
    </peripheral>
    <peripheral>
      <name>DMA1</name>
      <baseAddress>0x40020000</baseAddress>
      <interrupt>
        <name>DMA1_Channel1</name>
        <value>9</value>
      </interrupt>
    </peripheral>
    <peripheral>
      <name>FDCAN1</name>
      <baseAddress>0x4000A000</baseAddress>
      <interrupt>
        <name>FDCAN1_IT0</name>
        <value>19</value>
      </interrupt>
    </peripheral>
  </peripherals>
</device>

<?xml version="1.0" encoding="UTF-8"?>
<!--
  Minimal modm-devices fixture for STM32G071RB.

  Trimmed-down vs. real modm output: only carries the fields the
  alloy adapter parses (clock-tree edges, DMA request matrix,
  signal AF mappings).  Sufficient to exercise the parser +
  precedence merge in tests without shipping the full ~3500-file
  modm tree.
-->
<device device-name="g071rb" platform="stm32" family="g0">
  <attribute name="core">cortex-m0plus</attribute>

  <driver name="rcc" type="stm32">
    <signal source="hsi16" target="sysclk"/>
    <signal source="hse" target="sysclk"/>
    <signal source="pll_r" target="sysclk"/>
    <signal source="hsi16" target="pll_in"/>
    <signal source="hse" target="pll_in"/>
    <signal source="pll_in" target="pll_r" multiplier="8"/>
    <signal source="sysclk" target="hclk" divisor="1"/>
    <signal source="hclk" target="pclk" divisor="1"/>
  </driver>

  <driver name="dma" type="stm32-mux">
    <request name="ADC1" peripheral="ADC1" signal="" channel="5"/>
    <request name="USART1_RX" peripheral="USART1" signal="RX" channel="50"/>
    <request name="USART1_TX" peripheral="USART1" signal="TX" channel="51"/>
    <request name="USART2_RX" peripheral="USART2" signal="RX" channel="52"/>
    <request name="USART2_TX" peripheral="USART2" signal="TX" channel="53"/>
    <request name="SPI1_RX" peripheral="SPI1" signal="RX" channel="16"/>
    <request name="SPI1_TX" peripheral="SPI1" signal="TX" channel="17"/>
  </driver>

  <driver name="gpio" type="stm32">
    <gpio port="A" pin="0">
      <signal driver="usart" instance="2" name="cts" af="1"/>
      <signal driver="tim" instance="2" name="ch1" af="2"/>
    </gpio>
    <gpio port="A" pin="2">
      <signal driver="usart" instance="2" name="tx" af="1"/>
    </gpio>
    <gpio port="A" pin="3">
      <signal driver="usart" instance="2" name="rx" af="1"/>
    </gpio>
    <gpio port="A" pin="5">
      <signal driver="spi" instance="1" name="sck" af="0"/>
    </gpio>
  </driver>
</device>

<?xml version="1.0"?>
<!--
  Copyright (c) 2021-2024 Microchip Technology Inc.
  SPDX-License-Identifier: Apache-2.0

  alloy-codegen bootstrap fixture for add-microchip-avr-da-target Phase 0.5/0.6.
  Minimal subset of the full Atmel AVR-Dx DFP AVR128DA32 ATDF — contains only:
    * the device header (name, architecture)
    * the three Harvard address-spaces (prog, data, eeprom)
    * a handful of peripherals (USART, TWI, SPI, TCA) to exercise canonical
      class resolution
    * a few peripheral interrupts

  This is sufficient to satisfy Phase 0.6 (fetch produces a non-empty raw
  document) and to prove the source adapter accepts ATDF-only devices.
  Full register/pin/PORTMUX data lands in Phase 2.
-->
<avr-tools-device-file xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" schema-version="4.2">
  <variants>
    <variant ordercode="AVR128DA32-I/PT" package="TQFP32" pinout="TQFP32" speedmax="24000000" tempmax="+85" tempmin="-40" vccmax="5.5" vccmin="1.8"/>
  </variants>
  <devices>
    <device architecture="AVR8X" family="AVR" name="AVR128DA32" series="AVR-DA">
      <address-spaces>
        <address-space id="prog" name="prog" endianness="little" size="0x20000" start="0x0">
          <memory-segment name="APP_SECTION" start="0x0" size="0x20000" type="flash" exec="true" rw="R" pagesize="0x200"/>
        </address-space>
        <address-space id="data" name="data" endianness="little" size="0x10000" start="0x0">
          <memory-segment name="MAPPED_PROGMEM" start="0x8000" size="0x8000" type="other" rw="R"/>
          <memory-segment name="INTERNAL_SRAM" start="0x4000" size="0x4000" type="ram" rw="RW"/>
          <memory-segment name="IO" start="0x0000" size="0x1000" type="io" rw="RW"/>
          <memory-segment name="EXT_IO" start="0x1000" size="0x3000" type="io" rw="RW"/>
        </address-space>
        <address-space id="eeprom" name="eeprom" endianness="little" size="0x200" start="0x1400">
          <memory-segment name="EEPROM" start="0x1400" size="0x200" type="eeprom" rw="RW" pagesize="0x1"/>
        </address-space>
        <address-space id="fuses" name="fuses" endianness="little" size="0x10" start="0x1050"/>
      </address-spaces>
      <peripherals>
        <module name="USART">
          <instance name="USART0" caption="Universal Synchronous/Asynchronous Receiver/Transmitter">
            <register-group name="USART0" name-in-module="USART" offset="0x800" address-space="data"/>
            <signals>
              <signal group="TXD" index="0" pad="PA0"/>
              <signal group="RXD" index="0" pad="PA1"/>
            </signals>
          </instance>
          <instance name="USART1" caption="Universal Synchronous/Asynchronous Receiver/Transmitter">
            <register-group name="USART1" name-in-module="USART" offset="0x820" address-space="data"/>
            <signals>
              <signal group="TXD" index="0" pad="PC0"/>
              <signal group="RXD" index="0" pad="PC1"/>
            </signals>
          </instance>
        </module>
        <module name="TWI">
          <instance name="TWI0" caption="Two-Wire Interface">
            <register-group name="TWI0" name-in-module="TWI" offset="0x8A0" address-space="data"/>
            <signals>
              <signal group="SDA" index="0" pad="PA2"/>
              <signal group="SCL" index="0" pad="PA3"/>
            </signals>
          </instance>
        </module>
        <module name="SPI">
          <instance name="SPI0" caption="Serial Peripheral Interface">
            <register-group name="SPI0" name-in-module="SPI" offset="0x8C0" address-space="data"/>
            <signals>
              <signal group="MOSI" index="0" pad="PA4"/>
              <signal group="MISO" index="0" pad="PA5"/>
              <signal group="SCK" index="0" pad="PA6"/>
              <signal group="SS" index="0" pad="PA7"/>
            </signals>
          </instance>
        </module>
        <module name="TCA">
          <instance name="TCA0" caption="16-bit Timer/Counter Type A">
            <register-group name="TCA0" name-in-module="TCA" offset="0xA00" address-space="data"/>
          </instance>
        </module>
        <module name="PORT">
          <instance name="PORTA" caption="I/O Ports">
            <register-group name="PORTA" name-in-module="PORT" offset="0x400" address-space="data"/>
          </instance>
          <instance name="PORTC" caption="I/O Ports">
            <register-group name="PORTC" name-in-module="PORT" offset="0x440" address-space="data"/>
          </instance>
        </module>
        <module name="CLKCTRL">
          <instance name="CLKCTRL" caption="Clock Controller">
            <register-group name="CLKCTRL" name-in-module="CLKCTRL" offset="0x60" address-space="data"/>
          </instance>
        </module>
      </peripherals>
      <interrupts>
        <interrupt index="0" name="RESET" caption="Reset Vector"/>
        <interrupt index="1" name="NMI" caption="Non-Maskable Interrupt from CRC"/>
        <interrupt index="18" name="USART0_RXC" caption="USART0 Receive complete"/>
        <interrupt index="19" name="USART0_DRE" caption="USART0 Data Register Empty"/>
        <interrupt index="20" name="USART0_TXC" caption="USART0 Transmit complete"/>
        <interrupt index="26" name="TWI0_TWIS" caption="TWI0 Slave"/>
        <interrupt index="27" name="TWI0_TWIM" caption="TWI0 Master"/>
        <interrupt index="28" name="SPI0_INT" caption="SPI0 Interrupt"/>
      </interrupts>
    </device>
  </devices>
  <!--
    Module register-group definitions.  In a real AVR-Dx DFP these are
    much richer (all bitfields, enumerated values, access masks, etc.).
    This fixture carries a minimal subset — enough for the ATDF register
    parser (Phase 2.4) to populate the canonical IR with CLKCTRL clock
    control registers and a handful of runtime-owned peripheral
    registers (USART CTRLA/CTRLB, TWI MCTRLA, SPI CTRLA, PORT DIR/OUT)
    so the runtime-peripherals-have-register-descriptors validation
    rule applies without any AVR exemption.
  -->
  <modules>
    <module name="CLKCTRL" caption="Clock Controller" id="CLKCTRL_V1">
      <register-group name="CLKCTRL" caption="Clock Controller">
        <register name="MCLKCTRLA" offset="0x00" size="1" initval="0x00" caption="MCLK Control A" rw="RW">
          <bitfield name="CLKSEL" mask="0x03" caption="Clock Select"/>
          <bitfield name="CLKOUT" mask="0x80" caption="System Clock Out"/>
        </register>
        <register name="MCLKCTRLB" offset="0x01" size="1" initval="0x00" caption="MCLK Control B" rw="RW">
          <bitfield name="PEN" mask="0x01" caption="Prescaler Enable"/>
          <bitfield name="PDIV" mask="0x1E" caption="Prescaler Division"/>
        </register>
        <register name="MCLKLOCK" offset="0x02" size="1" initval="0x00" caption="MCLK Lock" rw="RW">
          <bitfield name="LOCKEN" mask="0x01" caption="Lock Enable"/>
        </register>
        <register name="MCLKSTATUS" offset="0x03" size="1" initval="0x00" caption="MCLK Status" rw="R">
          <bitfield name="SOSC" mask="0x01" caption="System Oscillator Status"/>
          <bitfield name="OSCHFS" mask="0x10" caption="High-Frequency Oscillator Status"/>
        </register>
        <register name="OSCHFCTRLA" offset="0x10" size="1" initval="0x0C" caption="OSCHF Control A" rw="RW">
          <bitfield name="AUTOTUNE" mask="0x01" caption="Auto-Tune"/>
          <bitfield name="RUNSTDBY" mask="0x02" caption="Run in Standby"/>
          <bitfield name="FRQSEL" mask="0x3C" caption="Frequency Select"/>
        </register>
      </register-group>
    </module>
    <module name="USART" caption="Universal Synchronous/Asynchronous Receiver/Transmitter" id="USART_V1">
      <register-group name="USART" caption="USART">
        <register name="CTRLA" offset="0x05" size="1" initval="0x00" caption="Control A" rw="RW">
          <bitfield name="RXCIE" mask="0x80" caption="RX Complete Interrupt Enable"/>
          <bitfield name="TXCIE" mask="0x40" caption="TX Complete Interrupt Enable"/>
          <bitfield name="DREIE" mask="0x20" caption="Data Register Empty Interrupt Enable"/>
        </register>
        <register name="CTRLB" offset="0x06" size="1" initval="0x00" caption="Control B" rw="RW">
          <bitfield name="RXEN" mask="0x80" caption="Receiver Enable"/>
          <bitfield name="TXEN" mask="0x40" caption="Transmitter Enable"/>
        </register>
        <register name="STATUS" offset="0x04" size="1" initval="0x00" caption="Status" rw="RW">
          <bitfield name="RXCIF" mask="0x80" caption="Receive Complete Interrupt Flag"/>
          <bitfield name="TXCIF" mask="0x40" caption="Transmit Complete Interrupt Flag"/>
          <bitfield name="DREIF" mask="0x20" caption="Data Register Empty Interrupt Flag"/>
        </register>
      </register-group>
    </module>
    <module name="TWI" caption="Two-Wire Interface" id="TWI_V1">
      <register-group name="TWI" caption="TWI">
        <register name="CTRLA" offset="0x00" size="1" initval="0x00" caption="Control A" rw="RW">
          <bitfield name="SDAHOLD" mask="0x0C" caption="SDA Hold Time"/>
          <bitfield name="FMPEN" mask="0x02" caption="Fast Mode Plus Enable"/>
        </register>
        <register name="MCTRLA" offset="0x03" size="1" initval="0x00" caption="Master Control A" rw="RW">
          <bitfield name="ENABLE" mask="0x01" caption="Enable TWI Master"/>
          <bitfield name="SMEN" mask="0x02" caption="Smart Mode Enable"/>
        </register>
      </register-group>
    </module>
    <module name="SPI" caption="Serial Peripheral Interface" id="SPI_V1">
      <register-group name="SPI" caption="SPI">
        <register name="CTRLA" offset="0x00" size="1" initval="0x00" caption="Control A" rw="RW">
          <bitfield name="ENABLE" mask="0x01" caption="Enable SPI"/>
          <bitfield name="MASTER" mask="0x20" caption="Master Select"/>
          <bitfield name="CLK2X" mask="0x10" caption="Enable Double SPI Speed"/>
        </register>
        <register name="CTRLB" offset="0x01" size="1" initval="0x00" caption="Control B" rw="RW">
          <bitfield name="SSD" mask="0x04" caption="Slave Select Disable"/>
        </register>
      </register-group>
    </module>
    <module name="TCA" caption="16-bit Timer/Counter Type A" id="TCA_V1">
      <register-group name="TCA" caption="TCA">
        <register name="CTRLA" offset="0x00" size="1" initval="0x00" caption="Control A" rw="RW">
          <bitfield name="ENABLE" mask="0x01" caption="Enable"/>
          <bitfield name="CLKSEL" mask="0x0E" caption="Clock Select"/>
        </register>
      </register-group>
    </module>
    <module name="PORT" caption="I/O Ports" id="PORT_V1">
      <register-group name="PORT" caption="Port">
        <register name="DIR" offset="0x00" size="1" initval="0x00" caption="Data Direction" rw="RW">
          <bitfield name="DIR" mask="0xFF" caption="Data Direction"/>
        </register>
        <register name="OUT" offset="0x04" size="1" initval="0x00" caption="Output Value" rw="RW">
          <bitfield name="OUT" mask="0xFF" caption="Output Value"/>
        </register>
        <register name="IN" offset="0x08" size="1" initval="0x00" caption="Input Value" rw="R">
          <bitfield name="IN" mask="0xFF" caption="Input Value"/>
        </register>
      </register-group>
    </module>
  </modules>
</avr-tools-device-file>

<?xml version="1.0" encoding="utf-8"?>
<device>
  <name>STM32G0B1</name>
  <version>2.1</version>
  <description>STM32G0B1 bootstrap fixture</description>
  <peripherals>
    <peripheral>
      <name>GPIOA</name>
      <baseAddress>0x50000000</baseAddress>
      <registers>
        <register><name>MODER</name><addressOffset>0x00</addressOffset></register>
        <register><name>AFRL</name><addressOffset>0x20</addressOffset></register>
        <register><name>AFRH</name><addressOffset>0x24</addressOffset></register>
      </registers>
    </peripheral>
    <peripheral>
      <name>GPIOB</name>
      <baseAddress>0x50000400</baseAddress>
      <registers>
        <register><name>MODER</name><addressOffset>0x00</addressOffset></register>
        <register><name>AFRL</name><addressOffset>0x20</addressOffset></register>
        <register><name>AFRH</name><addressOffset>0x24</addressOffset></register>
      </registers>
    </peripheral>
    <peripheral>
      <name>RCC</name>
      <baseAddress>0x40021000</baseAddress>
      <registers>
        <register><name>IOPRSTR</name><addressOffset>0x24</addressOffset></register>
        <register><name>AHBRSTR</name><addressOffset>0x28</addressOffset></register>
        <register><name>APBRSTR1</name><addressOffset>0x2C</addressOffset></register>
        <register><name>APBRSTR2</name><addressOffset>0x30</addressOffset></register>
        <register><name>IOPENR</name><addressOffset>0x34</addressOffset></register>
        <register><name>AHBENR</name><addressOffset>0x38</addressOffset></register>
        <register><name>APBENR1</name><addressOffset>0x3C</addressOffset></register>
        <register><name>APBENR2</name><addressOffset>0x40</addressOffset></register>
      </registers>
      <interrupt>
        <name>RCC_CRS</name>
        <value>4</value>
      </interrupt>
    </peripheral>
    <peripheral>
      <name>DMA1</name>
      <baseAddress>0x40020000</baseAddress>
      <interrupt>
        <name>DMA1_Channel1</name>
        <value>9</value>
      </interrupt>
      <interrupt>
        <name>DMA1_Channel2_3</name>
        <value>10</value>
      </interrupt>
    </peripheral>
    <peripheral>
      <name>DMAMUX1</name>
      <baseAddress>0x40020800</baseAddress>
    </peripheral>
    <peripheral>
      <name>USART1</name>
      <baseAddress>0x40013800</baseAddress>
      <registers>
        <register><name>CR1</name><addressOffset>0x00</addressOffset></register>
        <register><name>CR2</name><addressOffset>0x04</addressOffset></register>
        <register><name>BRR</name><addressOffset>0x0C</addressOffset></register>
        <register><name>ISR</name><addressOffset>0x1C</addressOffset></register>
        <register><name>RDR</name><addressOffset>0x24</addressOffset></register>
        <register><name>TDR</name><addressOffset>0x28</addressOffset></register>
      </registers>
      <interrupt>
        <name>USART1</name>
        <value>27</value>
      </interrupt>
    </peripheral>
    <peripheral>
      <name>FDCAN1</name>
      <baseAddress>0x4000A000</baseAddress>
      <interrupt>
        <name>FDCAN1_IT0</name>
        <value>19</value>
      </interrupt>
    </peripheral>
  </peripherals>
</device>

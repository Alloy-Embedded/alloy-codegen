<?xml version="1.0" encoding="utf-8"?>
<device>
  <name>STM32G030</name>
  <version>2.1</version>
  <description>STM32G030 bootstrap fixture</description>
  <peripherals>
    <peripheral>
      <name>GPIOA</name>
      <baseAddress>0x50000000</baseAddress>
    </peripheral>
    <peripheral>
      <name>RCC</name>
      <baseAddress>0x40021000</baseAddress>
      <interrupt>
        <name>RCC_CRS</name>
        <value>4</value>
      </interrupt>
    </peripheral>
    <peripheral>
      <name>DMA1</name>
      <baseAddress>0x40020000</baseAddress>
      <interrupt>
        <name>DMA1_Channel1</name>
        <value>9</value>
      </interrupt>
    </peripheral>
    <peripheral>
      <name>USART2</name>
      <baseAddress>0x40004400</baseAddress>
      <interrupt>
        <name>USART2</name>
        <value>28</value>
      </interrupt>
    </peripheral>
  </peripherals>
</device>

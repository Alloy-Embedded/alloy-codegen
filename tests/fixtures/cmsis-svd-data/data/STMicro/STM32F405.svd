        <value>37</value>
      </interrupt>
    </peripheral>
    <peripheral>
      <name>USART2</name>
      <baseAddress>0x40004400</baseAddress>
      <interrupt>
        <name>USART2</name>
        <value>38</value>
      </interrupt>
    </peripheral>
    <peripheral>
      <name>OTG_FS</name>
      <baseAddress>0x50000000</baseAddress>

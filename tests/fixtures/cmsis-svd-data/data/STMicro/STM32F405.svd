<?xml version="1.0" encoding="utf-8"?>
<device>
  <name>STM32F405</name>
  <version>1.0</version>
  <description>STM32F405 bootstrap fixture</description>
  <peripherals>
    <peripheral>
      <name>GPIOA</name>
      <baseAddress>0x40020000</baseAddress>
      <registers>
        <register><name>MODER</name><addressOffset>0x00</addressOffset><fields><field><name>MODER2</name><bitOffset>4</bitOffset><bitWidth>2</bitWidth></field></fields></register>
        <register><name>AFRL</name><addressOffset>0x20</addressOffset></register>
        <register><name>AFRH</name><addressOffset>0x24</addressOffset></register>
      </registers>
    </peripheral>
    <peripheral>
      <name>GPIOB</name>
      <baseAddress>0x40020400</baseAddress>
      <registers>
        <register><name>MODER</name><addressOffset>0x00</addressOffset><fields><field><name>MODER6</name><bitOffset>12</bitOffset><bitWidth>2</bitWidth></field></fields></register>
        <register><name>AFRL</name><addressOffset>0x20</addressOffset></register>
        <register><name>AFRH</name><addressOffset>0x24</addressOffset></register>
      </registers>
    </peripheral>
    <peripheral>
      <name>RCC</name>
      <baseAddress>0x40023800</baseAddress>
      <registers>
        <register><name>AHB1RSTR</name><addressOffset>0x10</addressOffset></register>
        <register><name>AHB2RSTR</name><addressOffset>0x14</addressOffset></register>
        <register><name>APB1RSTR</name><addressOffset>0x20</addressOffset></register>
        <register><name>APB2RSTR</name><addressOffset>0x24</addressOffset></register>
        <register><name>AHB1ENR</name><addressOffset>0x30</addressOffset></register>
        <register><name>AHB2ENR</name><addressOffset>0x34</addressOffset></register>
        <register><name>APB1ENR</name><addressOffset>0x40</addressOffset></register>
        <register><name>APB2ENR</name><addressOffset>0x44</addressOffset></register>
      </registers>
    </peripheral>
    <peripheral>
      <name>DMA1</name>
      <baseAddress>0x40026000</baseAddress>
      <interrupt>
        <name>DMA1_Stream0</name>
        <value>11</value>
      </interrupt>
    </peripheral>
    <peripheral>
      <name>DMA2</name>
      <baseAddress>0x40026400</baseAddress>
      <interrupt>
        <name>DMA2_Stream0</name>
        <value>56</value>
      </interrupt>
    </peripheral>
    <peripheral>
      <name>USART1</name>
      <baseAddress>0x40011000</baseAddress>
      <registers>
        <register><name>SR</name><addressOffset>0x00</addressOffset><fields><field><name>TXE</name><bitOffset>7</bitOffset><bitWidth>1</bitWidth></field></fields></register>
        <register><name>DR</name><addressOffset>0x04</addressOffset></register>
        <register><name>BRR</name><addressOffset>0x08</addressOffset></register>
        <register><name>CR1</name><addressOffset>0x0C</addressOffset></register>
        <register><name>CR2</name><addressOffset>0x10</addressOffset></register>
      </registers>
      <interrupt>
        <name>USART1</name>
        <value>37</value>
      </interrupt>
    </peripheral>
    <peripheral>
      <name>USART2</name>
      <baseAddress>0x40004400</baseAddress>
      <registers>
        <register><name>SR</name><addressOffset>0x00</addressOffset><fields><field><name>TXE</name><bitOffset>7</bitOffset><bitWidth>1</bitWidth></field></fields></register>
        <register><name>DR</name><addressOffset>0x04</addressOffset></register>
        <register><name>BRR</name><addressOffset>0x08</addressOffset></register>
        <register><name>CR1</name><addressOffset>0x0C</addressOffset></register>
        <register><name>CR2</name><addressOffset>0x10</addressOffset></register>
      </registers>
      <interrupt>
        <name>USART2</name>
        <value>38</value>
      </interrupt>
    </peripheral>
    <peripheral>
      <name>OTG_FS</name>
      <baseAddress>0x50000000</baseAddress>
      <interrupt>
        <name>OTG_FS</name>
        <value>67</value>
      </interrupt>
    </peripheral>
    <peripheral>
      <name>Ethernet_MAC</name>
      <baseAddress>0x40028000</baseAddress>
      <registers>
        <register><name>MACCR</name><addressOffset>0x00</addressOffset></register>
      </registers>
    </peripheral>
  </peripherals>
</device>
